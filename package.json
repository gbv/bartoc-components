{
  "name": "@gbv/bartoc-components",
  "version": "0.1.0",
  "description": "Shared Vue components, design tokens, and CSS utilities for BARTOC applications.",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/bartoc-components.umd.cjs",
  "module": "./dist/bartoc-components.js",
  "exports": {
    ".": {
      "import": "./dist/bartoc-components.js",
      "require": "./dist/bartoc-components.umd.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "prepack": "npm run build",
    "prepare": "npm run build",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.0",
    "typescript": "^5.0.0",
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  }
}
